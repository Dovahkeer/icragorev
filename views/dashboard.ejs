                                                </div>
                                              </form>
                                            <% } %>
                                          </div>
                                        <% }); %>
                                      <% } else { %>
                                        <div class="note-empty">Henüz not eklenmemiş.</div>
                                      <% } %>
                                    </div>

                                    <form method="POST" action="/tasks/<%= t.id %>/note" class="note-form scroll-form" enctype="multipart/form-data">
