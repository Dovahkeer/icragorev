<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tebligatlar - <%= username %>
    </title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <div class="app-container">
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="sidebar-header-info">
                    <h2>PORTFÖY İNCELEME VE FAKTORİNG GÖREV YÖNETİMİ</h2>
                    <p>
                        <%= username %> (<%= role %>)
                    </p>
                </div>
            </div>
            <nav class="sidebar-menu">
                <a href="/dashboard" class="menu-item">
                    <span class="menu-item-icon">📊</span>
                    <span>Ana Panel</span>
                </a>
                <a href="/all-tasks" class="menu-item">
                    <span class="menu-item-icon">📋</span>
                    <span>Tüm Görevler</span>
                </a>
                <a href="/tebligatlar" class="menu-item active">
                    <span class="menu-item-icon">📝</span>
                    <span>Tebligatlar</span>
                </a>
                <a href="/archive" class="menu-item">
                    <span class="menu-item-icon">📦</span>
                    <span>Arşiv</span>
                </a>
            </nav>
            <div class="sidebar-footer">
                <form method="GET" action="/logout">
                    <button type="submit" class="logout-btn">Çıkış Yap</button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            <div class="content-header">
                <h1>Tebligat Yönetimi</h1>
                <p class="breadcrumb">Tebligat oluşturma ve takip işlemleri</p>
            </div>

            <!-- Tebligat Oluştur -->
            <section id="tebligat-olustur" class="section active" style="margin-bottom: 2rem;">
                <h2>Tebligat Oluştur</h2>
                <form method="POST" action="/tebligat/create?<%= new URLSearchParams(filters).toString() %>"
                    class="task-form">
                    <input type="text" name="muvekkil" placeholder="Müvekkil">
                    <input type="text" name="portfoy" placeholder="Portföy">
                    <input type="text" name="taraf" placeholder="Taraf">
                    <input type="text" name="tckn_vkn" placeholder="TCKN / VKN">
                    <input type="text" name="barkod" placeholder="Barkod No">
                    <input type="text" name="dosya_no" placeholder="Dosya No *" required>
                    <input type="text" name="icra_dairesi" placeholder="İcra Dairesi *" required>
                    <div style="display:flex;gap:0.5rem;align-items:center;">
                        <label style="display:flex;gap:0.5rem;align-items:center;margin:0;">
                            <input type="radio" name="durum" value="itiraz" checked>
                            <span>İtiraz</span>
                        </label>
                        <label style="display:flex;gap:0.5rem;align-items:center;margin:0;">
                            <input type="radio" name="durum" value="gönderildi">
                            <span>Gönderildi</span>
                        </label>
                        <label style="display:flex;gap:0.5rem;align-items:center;margin:0;">
                            <input type="radio" name="durum" value="tebliğ">
                            <span>Kesinleşti</span>
                        </label>
                    </div>
                    <textarea name="not" placeholder="Not"></textarea>
                    <button type="submit">Oluştur</button>
                </form>
            </section>

            <!-- Filtreleme Bölümü -->
            <section class="section active" style="margin-bottom: 1.5rem;">
                <h2>Filtreleme</h2>
                <form id="filter-form" method="GET" action="/tebligatlar" class="task-form"
                    style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
                    <select name="durum" style="padding:0.75rem; border-radius:8px; border:1px solid #e0e0e0;">
                        <option value="">Tüm Durumlar</option>
                        <option value="gönderildi" <%=filters.durum==='gönderildi' ? 'selected' : '' %>>Gönderildi
                        </option>
                        <option value="itiraz" <%=filters.durum==='itiraz' ? 'selected' : '' %>>İtiraz</option>
                        <option value="tebliğ" <%=filters.durum==='tebliğ' ? 'selected' : '' %>>Kesinleşti
                        </option>
                        <option value="iade" <%=filters.durum==='iade' ? 'selected' : '' %>>İade</option>
                    </select>
                    <input type="text" name="icra_dairesi" placeholder="İcra Dairesi"
                        value="<%= filters.icra_dairesi || '' %>">
                    <input type="text" name="muvekkil" placeholder="Müvekkil" value="<%= filters.muvekkil || '' %>">
                    <select name="ekleyen" style="padding:0.75rem; border-radius:8px; border:1px solid #e0e0e0;">
                        <option value="">Tüm Kullanıcılar</option>
                        <% users.forEach(function(u) { %>
                            <option value="<%= u.id %>" <%=filters.ekleyen==u.id ? 'selected' : '' %>><%= u.username %>
                            </option>
                            <% }) %>
                    </select>
                    <div style="display: flex; gap: 0.5rem;">
                        <button type="submit" style="flex: 1;">Filtrele</button>
                        <a href="/tebligatlar"
                            style="padding:0.75rem 1.5rem; background:#6b7280; color:white; border:none; border-radius:8px; cursor:pointer; text-decoration:none; display:inline-block; text-align:center;">Temizle</a>
                    </div>
                </form>
            </section>

            <!-- Tebligat Listesi - Modern Tablo -->
            <section id="tebligat-listesi" class="section active">
                <h2>Tebligat Listesi (<%= tebligatlar.length %> kayıt)</h2>
                <% if (tebligatlar && tebligatlar.length) { %>
                    <div class="modern-table-wrapper">
                        <table class="modern-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Dosya No</th>
                                    <th>İcra Dairesi</th>
                                    <th>Müvekkil</th>
                                    <th>Portföy</th>
                                    <th>Taraf</th>
                                    <th>TCKN/VKN</th>
                                    <th>Tarih</th>
                                    <th>Barkod</th>
                                    <th>Not</th>
                                    <th>Ekleyen</th>
                                    <th>İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% tebligatlar.forEach(function(t){ %>
                                    <tr>
                                        <td><span class="id-badge">#<%= t.id %></span></td>
                                        <td><strong>
                                                <%= t.dosya_no || '-' %>
                                            </strong></td>
                                        <td>
                                            <%= t.icra_dairesi || '-' %>
                                        </td>
                                        <td>
                                            <%= t.muvekkil || '-' %>
                                        </td>
                                        <td>
                                            <%= t.portfoy || '-' %>
                                        </td>
                                        <td>
                                            <%= t.taraf || '-' %>
                                        </td>
                                        <td>
                                            <%= t.tckn_vkn || '-' %>
                                        </td>
                                        <td>
                                            <%= t.tarih %>
                                        </td>
                                        <td>
                                            <form method="POST"
                                                action="/tebligat/<%= t.id %>/update-barkod?<%= new URLSearchParams(filters).toString() %>"
                                                class="scroll-form" style="margin:0;">
                                                <input type="text" name="barkod" value="<%= t.barkod || '' %>"
                                                    placeholder="Barkod"
                                                    style="padding:0.4rem; border-radius:6px; border:1px solid #e0e0e0; width:120px;">
                                                <button type="submit"
                                                    style="padding:0.4rem 0.6rem; background:#10b981; color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.85rem;">✓</button>
                                            </form>
                                        </td>
                                        <td>
                                            <form method="POST"
                                                action="/tebligat/<%= t.id %>/update-not?<%= new URLSearchParams(filters).toString() %>"
                                                class="scroll-form" style="margin:0;">
                                                <textarea name="notlar" placeholder="Not ekle..."
                                                    style="padding:0.4rem; border-radius:6px; border:1px solid #e0e0e0; width:200px; min-height:60px; resize:vertical;"><%= t.notlar || '' %></textarea>
                                                <button type="submit"
                                                    style="padding:0.4rem 0.6rem; background:#10b981; color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.85rem; margin-top:0.25rem;">Kaydet</button>
                                            </form>
                                        </td>
                                        <td>
                                            <form method="POST"
                                                action="/tebligat/<%= t.id %>/update-user?<%= new URLSearchParams(filters).toString() %>"
                                                class="scroll-form" style="margin:0;">
                                                <select name="created_by"
                                                    style="padding:0.4rem; border-radius:6px; border:1px solid #e0e0e0; width:120px;">
                                                    <option value="">Seçiniz</option>
                                                    <% users.forEach(function(u) { %>
                                                        <option value="<%= u.id %>" <%=t.created_by==u.id ? 'selected'
                                                            : '' %>><%= u.username %>
                                                        </option>
                                                        <% }) %>
                                                </select>
                                                <button type="submit"
                                                    style="padding:0.4rem 0.6rem; background:#10b981; color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.85rem; margin-top:0.25rem;">✓</button>
                                            </form>
                                        </td>
                                        <td>
                                            <div style="display:flex; gap:0.5rem; align-items:center;">
                                                <form method="POST"
                                                    action="/tebligat/<%= t.id %>/update-status?<%= new URLSearchParams(filters).toString() %>"
                                                    class="scroll-form"
                                                    style="display:flex; gap:0.5rem; align-items:center; flex:1;">
                                                    <select name="durum"
                                                        style="padding:0.5rem; border-radius:6px; border:1px solid #e0e0e0; flex:1;">
                                                        <option value="">Tebliğ</option>

                                                        <option value="gönderildi" <%=t.durum==='gönderildi'
                                                            ? 'selected' : '' %>>Gönderildi</option>
                                                        <option value="itiraz" <%=t.durum==='itiraz' ? 'selected' : ''
                                                            %>>İtiraz</option>
                                                        <option value="tebliğ" <%=t.durum==='tebliğ' ? 'selected' : ''
                                                            %>>Kesinleşti</option>
                                                        <option value="iade" <%=t.durum==='iade' ? 'selected' : '' %>>
                                                            İade</option>
                                                    </select>
                                                    <button type="submit"
                                                        style="padding:0.5rem 1rem; background:#667eea; color:white; border:none; border-radius:6px; cursor:pointer;">Güncelle</button>
                                                </form>
                                                <% if (role==='yonetici' ) { %>
                                                    <form method="POST"
                                                        action="/tebligat/<%= t.id %>/delete?<%= new URLSearchParams(filters).toString() %>"
                                                        class="scroll-form" style="margin:0;">
                                                        <button type="submit"
                                                            onclick="return confirm('Bu tebligatı silmek istediğinizden emin misiniz?')"
                                                            style="padding:0.5rem 0.75rem; background:#ef4444; color:white; border:none; border-radius:6px; cursor:pointer;"
                                                            title="Sil">🗑️</button>
                                                    </form>
                                                    <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                        <div class="empty-state">
                            <div class="empty-state-icon">📚</div>
                            <p>Tebligat bulunamadı</p>
                        </div>
                        <% } %>
            </section>
        </main>
    </div>
    <script>
        window.__scrollLockConfig = {
            storageKey: 'scroll-lock:/tebligatlar',
            formSelector: 'form.scroll-form'
        };
    </script>
    <script src="/scroll-lock.js"></script>
</body>

</html>
