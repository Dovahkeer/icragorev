<!DOCTYPE html>
<html lang="tr">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Arşiv - <%= username %>
  </title>
  <link rel="stylesheet" href="/style.css">
</head>

<body>
  <div class="app-container">
    <aside class="sidebar">
      <div class="sidebar-header">
        <img src="/favicon.png" alt="Logo" class="sidebar-logo">
        <div class="sidebar-header-info">
          <h2>İCRA TAKİP</h2>
          <p>
            <%= username %>
          </p>
        </div>
      </div>

      <nav class="sidebar-menu">
        <a href="/dashboard" class="menu-item">
          <span class="menu-item-icon">📊</span>
          <span>Ana Panel</span>
        </a>
        <a href="/all-tasks" class="menu-item">
          <span class="menu-item-icon">📋</span>
          <span>Tüm Görevler</span>
        </a>
        <a href="/tebligatlar" class="menu-item">
          <span class="menu-item-icon">📝</span>
          <span>Tebligatlar</span>
        </a>
        <a href="/archive" class="menu-item active">
          <span class="menu-item-icon">📦</span>
          <span>Arşiv</span>
        </a>
      </nav>

      <div class="sidebar-footer">
        <form method="GET" action="/logout">
          <button type="submit" class="logout-btn">Çıkış Yap</button>
        </form>
      </div>
    </aside>

    <main class="main-content">
      <div class="content-header">
        <h1>Arşiv</h1>
        <p class="breadcrumb">Tamamlanan ve onaylanan görevler</p>
      </div>

      <!-- İstatistikler -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon purple">📦</div>
          <div class="stat-info">
            <h3>
              <%= tasks ? tasks.length : 0 %>
            </h3>
            <p>Arşivlenen Görevler</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon blue">📝</div>
          <div class="stat-info">
            <h3>
              <%= tebligatArsiv ? tebligatArsiv.length : 0 %>
            </h3>
            <p>Arşivlenen Tebligatlar</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon green">✅</div>
          <div class="stat-info">
            <h3>
              <%= tasks ? tasks.filter(t=> t.oncelik !== 'acil').length : 0 %>
            </h3>
            <p>Rutin Görevler</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon orange">🔥</div>
          <div class="stat-info">
            <h3>
              <%= tasks ? tasks.filter(t=> t.oncelik === 'acil').length : 0 %>
            </h3>
            <p>Acil Görevler</p>
          </div>
        </div>
      </div>

      <!-- Tebligat Arşivi -->
      <div class="section active" style="margin-bottom: 2rem;">
        <h2>Tebligat Arşivi</h2>
        <% if (tebligatArsiv && tebligatArsiv.length> 0) { %>
          <div class="table-container">
            <table class="modern-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Dosya No</th>
                  <th>İcra Dairesi</th>
                  <th>Müvekkil</th>
                  <th>Portföy</th>
                  <th>Taraf</th>
                  <th>TCKN/VKN</th>
                  <th>Barkod</th>
                  <th>Durum</th>
                  <% if (role==='atayan' ) { %>
                    <th>İşlemler</th>
                    <% } %>
                      <th>Tarih</th>
                      <th>Not</th>
                      <th>Arşivlenme</th>
                </tr>
              </thead>
              <tbody>
                <% tebligatArsiv.forEach(t=> { %>
                  <tr>
                    <td><span class="id-badge">#<%= t.id %></span></td>
                    <td><strong>
                        <%= t.dosya_no || '-' %>
                      </strong></td>
                    <td>
                      <%= t.icra_dairesi || '-' %>
                    </td>
                    <td>
                      <%= t.muvekkil || '-' %>
                    </td>
                    <td>
                      <%= t.portfoy || '-' %>
                    </td>
                    <td>
                      <%= t.taraf || '-' %>
                    </td>
                    <td>
                      <%= t.tckn_vkn || '-' %>
                    </td>
                    <td>
                      <%= t.barkod || '-' %>
                    </td>
                    <td>
                      <span class="status-badge status-kesinleşti">✅ Kesinleşti</span>
                    </td>
                    <td>
                      <%= t.tarih %>
                    </td>
                    <td>
                      <%= t.notlar || '-' %>
                    </td>
                    <td>
                      <%= t.arsivlenme_tarihi %>
                    </td>
                    <% if (role==='atayan' ) { %>
                      <td>
                        <form method="POST" action="/archive/tebligat/<%= t.id %>/delete" class="scroll-form"
                          style="margin:0;">
                          <button type="submit"
                            onclick="return confirm('Bu arşivlenmiş tebligatı kalıcı silmek istiyor musunuz?')"
                            style="padding:0.25rem 0.4rem; background:#ef4444; color:white; border:none; border-radius:6px;">Sil</button>
                        </form>
                      </td>
                      <% } %>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
          <% } else { %>
            <div class="empty-state">
              <div class="empty-state-icon">📝</div>
              <p>Arşivlenmiş tebligat bulunmuyor</p>
            </div>
            <% } %>
      </div>

      <!-- Görev Arşivi -->

      <div class="section active">
        <h2>Görev Arşivi</h2>
        <% if (tasks && tasks.length> 0) { %>
          <div class="table-container">
            <table class="modern-table">
              <thead>
                <tr>
                  <th>Öncelik</th>
                  <th>İşlem Türü</th>
                  <th>Adliye</th>
                  <th>Müvekkil</th>
                  <th>Portföy</th>
                  <th>İcra Dairesi</th>
                  <th>Esas No</th>
                  <th>Borçlu</th>
                  <th>TCKN</th>
                  <th>Durum</th>
                  <% if (role==='atayan' ) { %>
                    <th>İşlemler</th>
                    <% } %>
                      <th>Oluşturulma</th>
                      <th>Arşivlenme</th>
                </tr>
              </thead>
              <tbody>
                <% tasks.forEach(task=> { %>
                  <tr class="<%= task.oncelik === 'acil' ? 'urgent-row' : '' %>">
                    <td>
                      <span class="badge <%= task.oncelik === 'acil' ? 'badge-urgent' : 'badge-normal' %>">
                        <%= task.oncelik==='acil' ? '🔥' : '📋' %>
                      </span>
                    </td>
                    <td><strong>
                        <%= task.islem_turu || 'Görev' %>
                      </strong></td>
                    <td>
                      <%= task.adliye || '-' %>
                    </td>
                    <td>
                      <%= task.muvekkil || '-' %>
                    </td>
                    <td>
                      <%= task.portfoy || '-' %>
                    </td>
                    <td>
                      <%= task.icra_dairesi || '-' %>
                    </td>
                    <td>
                      <%= task.icra_esas_no || '-' %>
                    </td>
                    <td>
                      <%= task.borclu || '-' %>
                    </td>
                    <td>
                      <%= task.borclu_tckn_vkn || '-' %>
                    </td>
                    <td>
                      <% if (task.status === 'teyitlenmedi') { %>
                        <span class="status-badge status-iade">TEYITLENMEDI</span>
                      <% } else { %>
                        <span class="status-badge status-arsiv">ARSIV</span>
                      <% } %>
                    </td>
                    <td>
                      <%= task.eklenme_tarihi || '-' %>
                    </td>
                    <td>
                      <%= new Date(task.updated_at).toLocaleDateString('tr-TR') %>
                    </td>
                    <% if (role==='atayan' ) { %>
                      <td>
                        <form method="POST" action="/archive/tasks/<%= task.id %>/delete" class="scroll-form"
                          style="margin:0;">
                          <button type="submit"
                            onclick="return confirm('Bu arşivlenmiş görevi kalıcı silmek istiyor musunuz?')"
                            style="padding:0.25rem 0.4rem; background:#ef4444; color:white; border:none; border-radius:6px;">Sil</button>
                        </form>
                      </td>
                      <% } %>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
          <% } else { %>
            <div class="empty-state">
              <div class="empty-state-icon">📦</div>
              <p>Arşivlenmiş görev bulunmuyor</p>
            </div>
            <% } %>
      </div>
    </main>
  </div>
  <script>
    window.__scrollLockConfig = {
      storageKey: 'scroll-lock:/archive',
      formSelector: 'form.scroll-form'
    };
  </script>
  <script src="/scroll-lock.js"></script>
</body>

</html>
