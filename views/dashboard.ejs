                                                style="display:none; margin-top:0.5rem;">
                                                <input type="hidden" name="returnTo" value="adliye-listesi">
                                                <textarea name="note"><%= h.details %></textarea>
                                                <% if (h.attachment_path) { %>
                                                  <div class="note-current-attachment">
                                                    <a href="<%= getNoteAttachmentHref(h) %>" target="_blank" rel="noopener" class="note-attachment-link">
                                                      Mevcut ek: <%= getNoteAttachmentLabel(h) %>
                                                    </a>
