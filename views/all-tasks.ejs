<!DOCTYPE html>
<html lang="tr">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tüm Görevler - <%= username %>
  </title>
  <link rel="stylesheet" href="/style.css">
</head>

<body>
  <div class="app-container">
    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="sidebar-header-info">
          <h2>PORTFÖY İNCELEME VE FAKTORİNG GÖREV YÖNETİMİ</h2>
          <p>
            <%= username %> (<%= role %>)
          </p>
        </div>
      </div>
      <nav class="sidebar-menu">
        <a href="/dashboard" class="menu-item">
          <span class="menu-item-icon">📊</span>
          <span>Ana Panel</span>
        </a>
        <a href="/all-tasks" class="menu-item active">
          <span class="menu-item-icon">📋</span>
          <span>Tüm Görevler</span>
        </a>
        <a href="/tebligatlar" class="menu-item">
          <span class="menu-item-icon">📝</span>
          <span>Tebligatlar</span>
        </a>
        <a href="/archive" class="menu-item">
          <span class="menu-item-icon">📦</span>
          <span>Arşiv</span>
        </a>
      </nav>
      <div class="sidebar-footer">
        <form method="GET" action="/logout">
          <button type="submit" class="logout-btn">Çıkış Yap</button>
        </form>
      </div>
    </aside>

    <main class="main-content">
      <div class="content-header">
        <h1>Tüm Görevler</h1>
        <p class="breadcrumb">Sistemdeki tüm aktif görevler</p>
      </div>

      <!-- Filtre -->
      <div style="margin-bottom: 1.5rem; padding: 1rem; background: #f8f9fa; border-radius: 8px;">
        <form method="GET" action="/all-tasks" style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: end;">
          <div style="flex: 1; min-width: 150px;">
            <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #666;">Durum</label>
            <select name="status" style="width: 100%; padding: 0.5rem; border-radius: 6px; border: 1px solid #ddd;">
              <option value="">Tüm Durumlar</option>
              <option value="tamamlanmadi" <%=filterStatus==='tamamlanmadi' ? 'selected' : '' %>>Tamamlanmadı</option>
              <option value="kontrol_ediliyor" <%=filterStatus==='kontrol_ediliyor' ? 'selected' : '' %>>Kontrol
                Ediliyor</option>
              <option value="son_onay_bekliyor" <%=filterStatus==='son_onay_bekliyor' ? 'selected' : '' %>>Son Onay
                Bekliyor</option>
              <option value="iade" <%=filterStatus==='iade' ? 'selected' : '' %>>İade</option>
              <option value="tamamlandi" <%=filterStatus==='tamamlandi' ? 'selected' : '' %>>Tamamlandı</option>
              <option value="uygun" <%=filterStatus==='uygun' ? 'selected' : '' %>>Uygun</option>
            </select>
          </div>
          <div style="flex: 1; min-width: 150px;">
            <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #666;">Öncelik</label>
            <select name="oncelik" style="width: 100%; padding: 0.5rem; border-radius: 6px; border: 1px solid #ddd;">
              <option value="">Tüm Öncelikler</option>
              <option value="acil" <%=filterOncelik==='acil' ? 'selected' : '' %>>🔥 Acil</option>
              <option value="rutin" <%=filterOncelik==='rutin' ? 'selected' : '' %>>📋 Rutin</option>
            </select>
          </div>
          <div style="flex: 1; min-width: 150px;">
            <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #666;">Adliye</label>
            <input type="text" name="adliye" value="<%= filterAdliye || '' %>" placeholder="Adliye"
              style="width: 100%; padding: 0.5rem; border-radius: 6px; border: 1px solid #ddd;">
          </div>
          <div style="flex: 1; min-width: 150px;">
            <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #666;">Müvekkil</label>
            <input type="text" name="muvekkil" value="<%= filterMuvekkil || '' %>" placeholder="Müvekkil"
              style="width: 100%; padding: 0.5rem; border-radius: 6px; border: 1px solid #ddd;">
          </div>
          <div style="flex: 1; min-width: 150px;">
            <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #666;">Ekleyen</label>
            <select name="creator" style="width: 100%; padding: 0.5rem; border-radius: 6px; border: 1px solid #ddd;">
              <option value="">Tümü</option>
              <% users.forEach(function(u) { %>
                <option value="<%= u.id %>" <%=filterCreator==u.id ? 'selected' : '' %>>
                  <%= u.username %>
                </option>
                <% }); %>
            </select>
          </div>
          <div style="flex: 1; min-width: 150px;">
            <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #666;">Atanan</label>
            <select name="assignee" style="width: 100%; padding: 0.5rem; border-radius: 6px; border: 1px solid #ddd;">
              <option value="">Tümü</option>
              <% users.forEach(function(u) { %>
                <option value="<%= u.id %>" <%=filterAssignee==u.id ? 'selected' : '' %>>
                  <%= u.username %>
                </option>
                <% }); %>
            </select>
          </div>
          <div style="display: flex; gap: 0.5rem;">
            <button type="submit"
              style="padding: 0.5rem 1.5rem; background: #667eea; color: white; border: none; border-radius: 6px; cursor: pointer;">Filtrele</button>
            <a href="/all-tasks"
              style="padding: 0.5rem 1rem; background: #e0e0e0; color: #333; border: none; border-radius: 6px; text-decoration: none; display: inline-block;">Temizle</a>
          </div>
        </form>
      </div>

      <% if (tasks && tasks.length> 0) { %>
        <div class="table-container">
          <table class="modern-table">
            <thead>
              <tr>
                <th>Öncelik</th>
                <th>İşlem Türü</th>
                <th>Adliye</th>
                <th>Müvekkil</th>
                <th>Portföy</th>
                <th>İcra Dairesi</th>
                <th>Esas No</th>
                <th>Borçlu</th>
                <th>TCKN</th>
                <th>Atayan</th>
                <th>Yönetici</th>
                <th>Atanan</th>
                <th>Durum</th>
                <th>Tarih</th>
              </tr>
            </thead>
            <tbody>
              <% tasks.forEach(task=> {
                const creator = users.find(u => u.id === task.creator_id);
                const manager = users.find(u => u.id === task.manager_id);
                const assignee = users.find(u => u.id === task.assignee_id);
                %>
                <tr class="<%= task.oncelik === 'acil' ? 'urgent-row' : '' %>">
                  <td>
                    <span class="badge <%= task.oncelik === 'acil' ? 'badge-urgent' : 'badge-normal' %>">
                      <%= task.oncelik==='acil' ? '🔥' : '📋' %>
                    </span>
                  </td>
                  <td><strong>
                      <%= task.islem_turu || '-' %>
                    </strong></td>
                  <td>
                    <%= task.adliye || '-' %>
                  </td>
                  <td>
                    <%= task.muvekkil || '-' %>
                  </td>
                  <td>
                    <%= task.portfoy || '-' %>
                  </td>
                  <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
                    title="<%= task.icra_dairesi %>">
                    <%= task.icra_dairesi || '-' %>
                  </td>
                  <td>
                    <%= task.icra_esas_no || '-' %>
                  </td>
                  <td>
                    <%= task.borclu || '-' %>
                  </td>
                  <td>
                    <%= task.borclu_tckn_vkn || '-' %>
                  </td>
                  <td>
                    <%= creator ? creator.username : '-' %>
                  </td>
                  <td>
                    <%= manager ? manager.username : '-' %>
                  </td>
                  <td>
                    <%= assignee ? assignee.username : '-' %>
                  </td>
                  <td>
                    <span class="status-badge status-<%= task.status %>">
                      <%= task.status %>
                    </span>
                  </td>
                  <td>
                    <%= task.eklenme_tarihi || '-' %>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-state-icon">📭</div>
            <p>Görev bulunamadı</p>
          </div>
          <% } %>
    </main>
  </div>

    <script>
    window.__scrollLockConfig = {
      storageKey: 'scroll-lock:/all-tasks',
      formSelector: 'form[action="/all-tasks"], form.scroll-form',
      includeGet: true
    };
  </script>
  <script src="/scroll-lock.js"></script>
</body>

</html>
